# Supabase (Project Settings > API)
# 新しいキー体系（Publishable / Secret）を使う場合の対応:
#   NEXT_PUBLIC_SUPABASE_ANON_KEY  ← Publishable key（sb_publishable_...）※ブラウザ公開可・RLSで保護
#   SUPABASE_SERVICE_ROLE_KEY      ← Secret key（sb_secret_...）※サーバー専用・絶対に公開しない
# 旧キー体系なら anon / service_role をそのまま。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用（NEXT_PUBLIC を付けない）。本部管理者による会社・メンバー作成などの特権操作に使用。
SUPABASE_SERVICE_ROLE_KEY=

# LINE Developers（募集の入口となるLINE連携。将来接続。仕様書9章「未実装」参照）
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
NEXT_PUBLIC_LIFF_ID=
